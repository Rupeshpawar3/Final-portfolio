{
    "rewrites": [
        {
            "source": "/((?!assets|projects|videos|work|svgs|.*\\.(?:ico|png|jpg|jpeg|gif|svg|webp|avif|mp4|pdf|txt|js|css|woff|woff2)).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/projects/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}